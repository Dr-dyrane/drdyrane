{
  "name": "drdyrane",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "audit:contrast": "node scripts/contrast-audit.mjs",
    "e2e:malaria": "node scripts/e2e-malaria.mjs",
    "e2e:fever-bias": "node scripts/e2e-fever-bias.mjs",
    "e2e:contracts": "node scripts/e2e-rpc-contracts.mjs",
    "e2e:matrix": "node scripts/e2e-matrix.mjs --mode mock",
    "e2e:deterministic": "npm run e2e:matrix",
    "e2e:integration": "node scripts/e2e-transcript-replay.mjs",
    "e2e:integration:strict": "node scripts/e2e-transcript-replay.mjs --require-llm",
    "test:ui": "playwright test",
    "test:ui:engines": "playwright test tests/playwright/engine-smoke.spec.ts",
    "test:ui:scan": "playwright test tests/playwright/scan-treatment-synthesis.spec.ts",
    "test:ui:consult": "playwright test tests/playwright/consult-flow.spec.ts",
    "test:ui:consult:regression": "playwright test tests/playwright/consult-flow.spec.ts tests/playwright/consult-loop-regression.spec.ts tests/playwright/consult-retry-resilience.spec.ts tests/playwright/consult-media-intake.spec.ts tests/playwright/consult-gate-options-resilience.spec.ts tests/playwright/consult-gate-reload-persistence.spec.ts tests/playwright/consult-option-normalization.spec.ts tests/playwright/consult-summary-ready-progress.spec.ts tests/playwright/consult-reset-race-resilience.spec.ts tests/playwright/consult-message-polish.spec.ts tests/playwright/consult-invariant-audit.spec.ts tests/playwright/consult-stale-state-replay.spec.ts",
    "test:ui:install": "playwright install chromium",
    "test:quality": "npm run lint && npm run e2e:deterministic && npm run test:ui:engines && npm run test:ui:scan && npm run test:ui:consult:regression"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  }
}
